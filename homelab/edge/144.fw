[OPTIONS]
enable: 1
policy_in: DROP
policy_out: DROP

[RULES]
# --- Entrant : seulement le web public (le reste DROP ; pct exec passe hors réseau) ---
IN ACCEPT -p tcp -dport 80
IN ACCEPT -p tcp -dport 443
IN ACCEPT -p udp -dport 443
IN ACCEPT -p udp -dport 68

# --- Sortant : services réseau de base ---
OUT ACCEPT -p udp -dport 67
OUT ACCEPT -p udp -dport 53
OUT ACCEPT -p tcp -dport 53

# --- Sortant : les 9 upstreams autorisés (IP:port précis) ---
OUT ACCEPT -dest 192.168.1.96 -p tcp -dport 8080
OUT ACCEPT -dest 192.168.1.50 -p tcp -dport 8096
OUT ACCEPT -dest 192.168.1.58 -p tcp -dport 30000
OUT ACCEPT -dest 192.168.1.98 -p tcp -dport 80
OUT ACCEPT -dest 192.168.1.78 -p tcp -dport 8080
OUT ACCEPT -dest 192.168.1.41 -p tcp -dport 5055
OUT ACCEPT -dest 192.168.1.42 -p tcp -dport 3000
OUT ACCEPT -dest 192.168.1.30 -p tcp -dport 3000

# --- Sortant : tout le reste du LAN / tailnet = DENY (proxmox, NAS, autres) ---
OUT DROP -dest 192.168.0.0/16
OUT DROP -dest 10.0.0.0/8
OUT DROP -dest 172.16.0.0/12
OUT DROP -dest 100.64.0.0/10

# --- Sortant : internet (ACME, pulls Docker, hub CrowdSec) — LAN déjà filtré au-dessus ---
OUT ACCEPT -p tcp -dport 443
OUT ACCEPT -p tcp -dport 80
