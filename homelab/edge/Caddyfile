{
	order crowdsec first
	crowdsec {
		api_url http://crowdsec:8080
		api_key {env.CROWDSEC_BOUNCER_KEY}
	}
}

# Snippet appliqué à chaque vhost public : blocage CrowdSec + log JSON
# (le log alimente l'acquisition CrowdSec via /var/log/caddy/access.log).
(prot) {
	crowdsec
	log {
		output file /var/log/caddy/access.log
		format json
	}
}

